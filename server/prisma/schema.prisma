generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Game {
  id         String   @id @unique @default(uuid())
  players    Player[]
  inProgress Boolean  @default(false)
}

model Player {
  id        String   @id @unique @default(uuid())
  name      String
  createdAt DateTime @default(now())
  Game      Game     @relation(fields: [gameId], references: [id])
  gameId    String

  @@unique([name, gameId])
}
